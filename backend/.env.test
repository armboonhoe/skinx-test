# Test environment — uses a separate database from dev
DATABASE_URL="postgresql://skinx:skinx_dev_password@localhost:5432/skinx_posts_test?schema=public"

PORT=4100
NODE_ENV=test
LOG_LEVEL=error

JWT_SECRET="test-secret-0123456789abcdef0123456789abcdef0123456789abcdef"
JWT_EXPIRES_IN="1h"

CORS_ORIGIN="http://localhost:3000"
TRUST_PROXY="false"

SEED_FILE_PATH="../posts.json"
SEED_DEMO_EMAIL="demo@skinx.local"
SEED_DEMO_PASSWORD="Demo@1234"
