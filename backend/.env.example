# Database
DATABASE_URL="postgresql://skinx:skinx_dev_password@localhost:5432/skinx_posts?schema=public"

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Auth — CHANGE IN PRODUCTION (min 32 chars)
JWT_SECRET="change-me-to-a-long-random-string-min-32-characters"
JWT_EXPIRES_IN="7d"

# CORS — comma-separated origins
CORS_ORIGIN="http://localhost:3000"

# Trust proxy — "false" for direct exposure, number of hops, or trusted IP/CIDR.
# NEVER set to "true" in production behind a non-exclusive proxy: X-Forwarded-For
# becomes spoofable → rate-limit bypass.
TRUST_PROXY="false"

# Seed
SEED_FILE_PATH="../posts.json"
SEED_DEMO_EMAIL="demo@skinx.local"
SEED_DEMO_PASSWORD="Demo@1234"
